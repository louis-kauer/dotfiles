{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "background": "#326ce5",
          "foreground": "#ffffff",
          "style": "diamond",
          "template": " ☸ {{ .Context }} ",
          "trailing_diamond": "\ue0b0",
          "type": "kubectl"
        },
        {
          "background": "#ffffff",
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "properties": {
            "folder_icon": "\uf115",
            "folder_separator_icon": " \ue0b1 ",
            "max_depth": 2,
            "style": "agnoster_short"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#95ffa4",
          "foreground": "#193549",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " {{ .HEAD }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "CPU {{ .System.CPU.Percentage | printf \"%0.0f\" }}% | RAM {{ .System.Memory.Percentage | printf \"%0.0f\" }}%",
  "final_space": true,
  "version": 3
}
